# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; this template is committed for reference.

# Database — pick ONE of the two configs below.
#
# OPTION A: Local MySQL (default, for local dev)
# Use Laragon / XAMPP / MAMP with MySQL on port 3306.
# Create a database named "portofoliobeta" first, then run `npm run db:init`.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=portofoliobeta

# OPTION B: TiDB Cloud Serverless (for production)
# Sign up at https://tidbcloud.com, create cluster, get connection details.
# Requires SSL (already enabled in lib/db.ts). Set DEBUG_MODE=false in production.
# DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
# DB_PORT=4000
# DB_USER='<prefix>.root'
# DB_PASSWORD='<your-password>'
# DB_NAME='<your-database>'

# Admin auth
ADMIN_PASSWORD=changeme
ADMIN_SECRET=replace-with-32-byte-random-string

# Public site URL (used for hotlink protection + auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob (auto-injected by Vercel when you create a Blob store).
# Leave empty in local dev — lib/blob.ts will fallback to writing to
# public/uploads/ on disk.
# BLOB_READ_WRITE_TOKEN=

# Debug mode
# "true"  — verbose DB query logs + stack traces in console
# "false" — silent (use in production)
DEBUG_MODE=false
