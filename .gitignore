# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# local env files
.env*.local
.env
.env.*.local
.env.production.local
.env.test.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.sentryclirc

# IDE / Editor
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# OS
Thumbs.db
ehthumbs.db
.AppleDouble
.LSOverride
._*

# Cache
.cache/
.eslintcache
.turbo/

# User-uploaded assets (admin uploads — keep folder structure via .gitkeep)
/public/uploads/tech/icon/*
!/public/uploads/tech/icon/.gitkeep
/public/uploads/covers/*
!/public/uploads/covers/.gitkeep
/public/uploads/avatars/*
!/public/uploads/avatars/.gitkeep

# Database backups (output of `npm run db:backup`)
/backups/

# Temp files
/tmp/
/temp/
*.tmp
